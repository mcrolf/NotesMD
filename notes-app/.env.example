# Template only: copy to `.env` in this directory (`cp .env.example .env`) and edit.
# The real `.env` file is gitignored. Do not put production secrets here or in `.env.example`.

# --- PostgreSQL (used by `docker compose` in this folder) ---
POSTGRES_USER=notes
# Use a unique, strong password for your machine. Must match SPRING_DATASOURCE_PASSWORD below.
POSTGRES_PASSWORD=CHANGE_ME_local_postgres_password
POSTGRES_DB=notes
POSTGRES_PORT=5432

# --- Spring Boot API (export these in the shell when running `./gradlew bootRun`, or use your IDE run config) ---
# JDBC URL: use `localhost` when the API runs on the host and Postgres runs in DockerCompose.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/notes
SPRING_DATASOURCE_USERNAME=notes
# Must match POSTGRES_PASSWORD above.
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_local_postgres_password

# Required for the API to start (HS256 signing key, ≥ 32 UTF-8 bytes). Do not reuse demo values in production.
# Generate one: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48

# Optional API overrides:
# JWT_ISSUER=notes-api
# JWT_ACCESS_TOKEN_TTL=PT1H

# --- CORS (comma-separated Origin values; default in application.yml is usually enough for local dev) ---
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,null

# If the API runs inside Docker on the same Compose network as Postgres, use the service hostname:
# SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/notes

# --- Frontend (copy `frontend/.env.example` to `frontend/.env.local` — see docs) ---
# VITE_* values are exposed to the browser; never put server secrets in the frontend env files.
# VITE_API_URL=http://localhost:8080
