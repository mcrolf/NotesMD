# MN 260506 Copy to `.env` in this folder for local `docker compose`. Replace placeholder values; do not commit secrets.

# --- Postgres container (maps to docker-compose `postgres` service) ---
POSTGRES_USER=notes
POSTGRES_PASSWORD=changeme_replace_me
POSTGRES_DB=notes
POSTGRES_PORT=5432

# --- Browser CORS (comma-separated Origin values; default includes localhost:5173 + literal null for Electron file://) ---
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,null

# --- Spring Boot JDBC (API on host machine → DB in Docker: host is localhost) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/notes
SPRING_DATASOURCE_USERNAME=notes
SPRING_DATASOURCE_PASSWORD=changeme_replace_me

# If the API runs inside Docker on the same Compose network, use host `postgres` instead of localhost:
# SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/notes

# --- Vite frontend (`frontend/.env.local`; see `frontend/.env.example`) ---
# VITE_API_URL=http://localhost:8080
