# Template only: copy to `.env` in this directory (`cp .env.example .env`) and edit.
# The real `.env` file is gitignored. Do not put production secrets here or in `.env.example`.

# --- PostgreSQL (used by `docker compose` in this folder) ---
POSTGRES_USER=notes
# Use a unique, strong password for your machine. Must match SPRING_DATASOURCE_PASSWORD below.
POSTGRES_PASSWORD=CHANGE_ME_local_postgres_password
POSTGRES_DB=notesMD
POSTGRES_PORT=5432

# --- Spring Boot API ---
# Used by Docker Compose for the `api` service (env_file) and by host `./run.sh` when exported.
# JDBC URL: use `localhost` when the API runs on the host and Postgres runs in Compose.
# When both run via `docker compose up -d`, compose overrides the URL to `postgres:5432` automatically.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/notesMD
SPRING_DATASOURCE_USERNAME=notes
# Must match POSTGRES_PASSWORD above.
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_local_postgres_password

# HS256 signing key (≥ 32 UTF-8 bytes). Set explicitly for any shared or production-like run — generate one: openssl rand -base64 48
# If unset, application.yml supplies a solo-development default so the JVM can boot; never rely on that outside local experimentation or reuse demo values in production.
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48

# Optional API overrides:
# JWT_ISSUER=notesmd-api
# JWT_ACCESS_TOKEN_TTL=PT1H
# SERVER_PORT=8080

# --- CORS (comma-separated Origin values; default in application.yml is usually enough for local dev) ---
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,null

# --- NotesMD client ---
# The React + Electron client is in the separate notesmd-frontend repository.
# Users enter the API origin at Register; optional VITE_API_URL is documented there.
